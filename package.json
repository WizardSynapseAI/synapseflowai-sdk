{
  "name": "@synapseflowai/sdk",
  "version": "0.1.0",
  "description": "Official Node.js SDK for the SynapseFlowAI public REST API",
  "author": "SynapseFlowAI <dev@synapseflowai.com>",
  "license": "MIT",
  "homepage": "https://github.com/WizardSynapseAI/synapseflowai-sdk#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/WizardSynapseAI/synapseflowai-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/WizardSynapseAI/synapseflowai-sdk/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "synapseflowai",
    "automation",
    "workflow",
    "email",
    "marketing",
    "sdk"
  ]
}
